<%# locals: () %>

<% UserRole::ALL_ROLES.each do |role| %>
  <% if current_user&.administrator? %>
    <% if @user.role?(role) %>
      <%= link_to tag.i(tag.span(t(".revoke.#{role}"), :class => "visually-hidden"),
                        :class => "bi bi-star-fill fs-5 role-#{role} align-middle"),
                  user_role_path(@user, role),
                  :method => :delete,
                  :data => { :confirm => t(".revoke.are_you_sure", :name => @user.display_name, :role => role) } %>
    <% else %>
      <%= link_to tag.i(tag.span(t(".grant.#{role}"), :class => "visually-hidden"),
                        :class => "bi bi-star fs-5 role-#{role} align-middle"),
                  user_role_path(@user, role),
                  :method => :post,
                  :data => { :confirm => t(".grant.are_you_sure", :name => @user.display_name, :role => role) } %>
    <% end %>
  <% elsif @user.role?(role) %>
    <%= tag.i(tag.span(t(".title.#{role}"), :class => "visually-hidden"),
              :class => "bi bi-star-fill fs-5 role-#{role} align-middle") %>
  <% end %>
<% end %>
