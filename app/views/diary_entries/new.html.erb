<% content_for :head do %>
  <%= javascript_include_tag "diary_entry" %>
<% end %>

<% content_for :heading do %>
  <h1><%= @title %></h1>
<% end %>

<%= bootstrap_form_for @diary_entry do |f| %>
<%= render "form", :f => f, :diary_entry => @diary_entry, :lat => @lat, :lon => @lon, :zoom => @zoom %>
<% end %>
