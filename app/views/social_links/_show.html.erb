<ul class="list-unstyled social_links mb-0">
  <% social_links.each do |social_link| %>
    <li>
      <%= link_to social_link.parsed[:url], :class => "icon-link mw-100 text-body-secondary mb-2", :rel => "nofollow me" do %>
        <%= image_tag "social_link_icons/#{social_link.parsed[:platform].nil? ? 'website' : social_link.parsed[:platform]}.svg",
                      :alt => social_link.parsed[:platform].nil? ? t(".website") : social_link.parsed[:platform],
                      :size => "16" %>
        <% if social_link.parsed[:is_osm_related] %>
          <svg viewBox="0 0 200 215" width="34" height="34" class="mb-n2 ms-n3 mt-1 opacity-25 position-absolute" fill="currentColor">
            <path d="M0 0 45.04 17.16 90.07 0 111.87 8.32A68.7 68.7 0 0 0 80.48 81.37L74.63 86.17A75.8 75.8 0 0 0 90.5 116.09L78.04 128.56 67.77 126.98 10.53 184.19 0 180.16 17.15 135.12 0 90.08 17.15 45.04 0 .01ZM191.42 119.66 197.32 135.13 180.16 180.17 135.12 197.32 90.08 180.17 45.04 197.32 40.4 195.56 88.37 147.56 86.77 138.02 99.67 125.1A75.76 75.76 0 0 0 128.31 139.84L133.11 134A68.28 68.28 0 0 0 191.42 119.66Z"></path>
          </svg>
        <% end %>
        <span class="text-truncate">
          <%= social_link.parsed[:name] %>
        </span>
      <% end %>
    </li>
  <% end %>
</ul>
